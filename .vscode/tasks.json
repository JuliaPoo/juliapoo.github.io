{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "compile-to-html",
      "type": "typst",
      "command": "export",
      "export": {
        "format": "html"
      }
    },
    {
      "label": "compile-to-pdf",
      "type": "typst",
      "command": "export",
      "export": {
        "format": "pdf"
      }
    },
    {
      "label": "Export as Jekyll Template",
      "type": "process",
      "command": "python",
      "args": [
        "typst-postprocess.py",
        "${file}"
      ],
      "dependsOn": ["compile-to-html", "compile-to-pdf"],
      "dependsOrder": "sequence",
      "group": {
        "kind": "build",
        "isDefault": true // Set to false if you're debugging sub-tasks
      },
      "problemMatcher": []
    }
  ]
}